# Firefly III — application environment
# Copy this file to ".env" (no .example) and fill in the CHANGE_ME values.
# DB_PASSWORD here MUST match MYSQL_PASSWORD in .db.env.

# Application identity

APP_ENV=production
APP_DEBUG=false
SITE_OWNER=mail@example.com

# 32-character random string. Generate one with:
#   head /dev/urandom | LC_ALL=C tr -dc 'A-Za-z0-9' | head -c 32 && echo
# Avoid the characters #, <, >, =, &
APP_KEY=CHANGE_ME_TO_A_RANDOM_32_CHAR_STR

# Locale

DEFAULT_LANGUAGE=en_US
DEFAULT_LOCALE=equal
TZ=America/Chicago

# Log

APP_LOG_LEVEL=notice
AUDIT_LOG_LEVEL=emergency

# Database

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=firefly
DB_USERNAME=firefly
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_USE_SSL=false
MYSQL_SSL_VERIFY_SERVER_CERT=true

# Cookies

COOKIE_PATH="/"
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Mail (log only)

MAIL_MAILER=log
MAIL_HOST=null
MAIL_PORT=2525
MAIL_FROM=changeme@example.com
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

# Misc

APP_NAME=FireflyIII
BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_DRIVER=sync
SESSION_DRIVER=file
LOG_CHANNEL=stack
ENABLE_EXTERNAL_RATES=true
ENABLE_EXCHANGE_RATES=true
SEND_REGISTRATION_MAIL=true
SEND_ERROR_MESSAGE=true
SEND_LOGIN_NEW_IP_WARNING=true
DISABLE_FRAME_HEADER=false
DISABLE_CSP_HEADER=false

# Container start-up tuning

DKR_CHECK_SQLITE=true
DKR_RUN_MIGRATION=true
DKR_RUN_UPGRADE=true
DKR_RUN_VERIFY=true
DKR_RUN_REPORT=true
DKR_RUN_PASSPORT_INSTALL=true
