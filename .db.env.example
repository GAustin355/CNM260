# MariaDB environment
# Copy this file to ".db.env" (no .example) and fill in the password.
# MYSQL_PASSWORD here MUST match DB_PASSWORD in .env.

# Generates a strong root password automatically on first run.
MYSQL_RANDOM_ROOT_PASSWORD=yes

# Application database + user
MYSQL_USER=firefly
MYSQL_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_DATABASE=firefly
